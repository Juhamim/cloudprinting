generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  printJobs     PrintJob[]
  printers      Printer[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Printer {
  id          String        @id @default(cuid())
  name        String
  description String?
  agentId     String        @unique
  status      PrinterStatus @default(OFFLINE)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  printJobs   PrintJob[]
  lastSeen    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PrintJob {
  id          String      @id @default(cuid())
  title       String
  fileUrl     String
  fileKey     String?
  fileType    String
  fileSize    Int
  status      JobStatus   @default(QUEUED)
  copies      Int         @default(1)
  colorMode   ColorMode   @default(MONOCHROME)
  paperSize   PaperSize   @default(A4)
  orientation Orientation @default(PORTRAIT)
  priority    Priority    @default(NORMAL)
  pages       String?
  pagesPerSheet Int       @default(1)
  userId      String
  printerId   String
  user        User        @relation(fields: [userId], references: [id])
  printer     Printer     @relation(fields: [printerId], references: [id])
  errorMsg    String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum PrinterStatus {
  ONLINE
  OFFLINE
  BUSY
  ERROR
}

enum JobStatus {
  QUEUED
  PROCESSING
  PRINTING
  COMPLETED
  FAILED
  CANCELLED
}

enum ColorMode {
  COLOR
  MONOCHROME
}

enum PaperSize {
  A4
  A3
  LETTER
  LEGAL
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}
